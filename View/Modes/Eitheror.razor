@page "/modes/eitheror"

<PageTitle>Either-or mode</PageTitle>

<ModesSideNav></ModesSideNav>

<article>
    <h2>EITHER OR MODE</h2>

    <div class="info-bar">
        <span class="progress-bar">
            <span class="left-progress">

            </span>
        </span>

        <button class="bar-button">
            <img src="img/svg/mode/icons/arrow-clockwise.svg" alt="reset mode"/>
        </button>

        <button class="bar-button">
            <img src="img/svg/mode/icons/caret-right-fill.svg" alt="next character" />
        </button>

        <span class="progress-bar">
            <span class="right-progress">

            </span>
        </span>
    </div>

    <section>
        <button class="guess-button">
            ひ
        </button>

        <p class="latin-guess">HI</p>

        <button class="guess-button">
            ら
        </button>
    </section>
</article>