@code {
    protected enum ModesNav    { EITHEROR,    KEYBOARD, }
    protected enum SettingsNav { GRID,        FONTS,    }
    protected enum ContactNav  { INFORMATION, FORM,     }

    protected static ModesNav CurrentMode { get; set; } = ModesNav.EITHEROR;
    protected static SettingsNav CurrentSettings { get; set; } = SettingsNav.GRID;
    protected static ContactNav CurrentContact { get; set; } = ContactNav.INFORMATION;

    protected static bool Toggled = false;

    protected void ChangeMode(ModesNav next) => CurrentMode = next;
    protected void ChangeSettings(SettingsNav next) => CurrentSettings = next;
    protected void ChangeContact(ContactNav next) => CurrentContact = next;

    public void ToggleSideMenu() => Toggled = !Toggled;
}
